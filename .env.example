# Pocket ID Configuration (no trailing slash)
POCKET_ID_URL=https://pocket-id.company
POCKET_ID_API_KEY=EXAMPLE

# Outline Configuration (no trailing slash)
OUTLINE_URL=https://docs.example.com
OUTLINE_TOKEN=ol_api_EXAMPLE
OUTLINE_WEBHOOK_SECRET=ol_whs_EXAMPLE

# Auto-create missing groups in Outline (True/False)
AUTO_CREATE_GROUPS=False

# Regular expression to filter groups to sync (optional, case-insensitive)
#SYNC_GROUP_REGEX=
# Examples:
# Only sync groups starting with "wiki-"
#SYNC_GROUP_REGEX=^wiki-.*
# Only sync groups ending with "-outline"
#SYNC_GROUP_REGEX=.*-outline$
# Only sync groups named exactly "admins", "editors", or "viewers"
#SYNC_GROUP_REGEX=^(admins|editors|viewers)$

# Debug logs (True/False)
DEBUG=False
